<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppAccentColor">#247BFF</Color>
            <Color x:Key="AppAccentSoftColor">#17325A</Color>
            <Color x:Key="AppBackgroundStartColor">#07101D</Color>
            <Color x:Key="AppBackgroundEndColor">#0A111D</Color>
            <Color x:Key="AppHeaderSurfaceColor">#091423</Color>
            <Color x:Key="AppSidebarSurfaceColor">#08111F</Color>
            <Color x:Key="AppSurfaceColor">#111B2A</Color>
            <Color x:Key="AppSurfaceAltColor">#0D1726</Color>
            <Color x:Key="AppSurfaceRaisedColor">#142033</Color>
            <Color x:Key="AppInputSurfaceColor">#0D1623</Color>
            <Color x:Key="AppBorderColor">#24364F</Color>
            <Color x:Key="AppBorderStrongColor">#32537B</Color>
            <Color x:Key="AppTextPrimaryColor">#F4F7FB</Color>
            <Color x:Key="AppTextSecondaryColor">#AAB4C3</Color>
            <Color x:Key="AppTextTertiaryColor">#8B97A8</Color>
            <Color x:Key="AppDropActiveColor">#12243B</Color>
            <Color x:Key="AppStatusSurfaceColor">#0F1827</Color>
            <Color x:Key="AppButtonGhostColor">#111C2B</Color>
            <Color x:Key="AppPrimaryActionColor">#247BFF</Color>
            <Color x:Key="AppPrimaryActionForegroundColor">#F4F7FB</Color>
            <Color x:Key="AppBrightBlueColor">#3BA0FF</Color>
            <Color x:Key="AppCyanColor">#45D6FF</Color>
            <Color x:Key="AppSuccessColor">#42E8C6</Color>
            <Color x:Key="AppWarningColor">#FFB74D</Color>
            <Color x:Key="AppDangerColor">#FF4D68</Color>
            <Color x:Key="AppMetadataColor">#9B5CFF</Color>
            <Color x:Key="AppWarningBackgroundColor">#241409</Color>
            <Color x:Key="AppDangerBackgroundColor">#281018</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppAccentColor">#1E67D1</Color>
            <Color x:Key="AppAccentSoftColor">#DDEAFE</Color>
            <Color x:Key="AppBackgroundStartColor">#F4F8FC</Color>
            <Color x:Key="AppBackgroundEndColor">#E8EEF6</Color>
            <Color x:Key="AppHeaderSurfaceColor">#F8FBFF</Color>
            <Color x:Key="AppSidebarSurfaceColor">#F4F7FB</Color>
            <Color x:Key="AppSurfaceColor">#FFFFFF</Color>
            <Color x:Key="AppSurfaceAltColor">#F5F8FC</Color>
            <Color x:Key="AppSurfaceRaisedColor">#EDF3FB</Color>
            <Color x:Key="AppInputSurfaceColor">#F6F9FD</Color>
            <Color x:Key="AppBorderColor">#D6E0ED</Color>
            <Color x:Key="AppBorderStrongColor">#B6C7DE</Color>
            <Color x:Key="AppTextPrimaryColor">#16202B</Color>
            <Color x:Key="AppTextSecondaryColor">#566578</Color>
            <Color x:Key="AppTextTertiaryColor">#5F6F82</Color>
            <Color x:Key="AppDropActiveColor">#E6F1FF</Color>
            <Color x:Key="AppStatusSurfaceColor">#F7FAFD</Color>
            <Color x:Key="AppButtonGhostColor">#EFF4FA</Color>
            <Color x:Key="AppPrimaryActionColor">#1E67D1</Color>
            <Color x:Key="AppPrimaryActionForegroundColor">#FFFFFF</Color>
            <Color x:Key="AppBrightBlueColor">#2D8AF2</Color>
            <Color x:Key="AppCyanColor">#16A7D8</Color>
            <Color x:Key="AppSuccessColor">#19B79B</Color>
            <Color x:Key="AppWarningColor">#B76300</Color>
            <Color x:Key="AppDangerColor">#E04461</Color>
            <Color x:Key="AppMetadataColor">#7B52DC</Color>
            <Color x:Key="AppWarningBackgroundColor">#FFF8ED</Color>
            <Color x:Key="AppDangerBackgroundColor">#FFF0F3</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="Spacing2">2</x:Double>
    <x:Double x:Key="Spacing4">4</x:Double>
    <x:Double x:Key="Spacing8">8</x:Double>
    <x:Double x:Key="Spacing12">12</x:Double>
    <x:Double x:Key="Spacing16">16</x:Double>
    <x:Double x:Key="Spacing20">20</x:Double>
    <x:Double x:Key="Spacing24">24</x:Double>
    <x:Double x:Key="Spacing32">32</x:Double>
    <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="PanelCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">8</CornerRadius>
    <Thickness x:Key="PanelPadding">22</Thickness>
    <Thickness x:Key="StatusPanelPadding">22</Thickness>
    <Thickness x:Key="StandardSpacing">16</Thickness>
    <Thickness x:Key="FocusRingMargin">2</Thickness>
    <GridLength x:Key="SidebarWidth">260</GridLength>
    <Thickness x:Key="StandardBorderThickness">1</Thickness>

    <SolidColorBrush x:Key="MainWindowBackgroundBrush" Color="{ThemeResource AppBackgroundStartColor}" />
    <SolidColorBrush x:Key="HeroSurfaceBrush" Color="{ThemeResource AppSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="SoftPanelBrush" Color="{ThemeResource AppSurfaceAltColor}" />
    <SolidColorBrush x:Key="DashboardAccentBrush" Color="{ThemeResource AppAccentColor}" />

    <SolidColorBrush x:Key="HeaderSurfaceBrush" Color="{ThemeResource AppHeaderSurfaceColor}" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="{ThemeResource AppSidebarSurfaceColor}" />
    <SolidColorBrush x:Key="WorkspaceSurfaceBrush" Color="{ThemeResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="InspectorSurfaceBrush" Color="{ThemeResource AppSurfaceAltColor}" />
    <SolidColorBrush x:Key="RaisedSurfaceBrush" Color="{ThemeResource AppSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="InputSurfaceBrush" Color="{ThemeResource AppInputSurfaceColor}" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="{ThemeResource AppBorderColor}" />
    <SolidColorBrush x:Key="AppBorderStrongBrush" Color="{ThemeResource AppBorderStrongColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource AppTextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{ThemeResource AppTextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{ThemeResource AppTextTertiaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource AppAccentColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{ThemeResource AppAccentSoftColor}" />
    <SolidColorBrush x:Key="BrightBlueBrush" Color="{ThemeResource AppBrightBlueColor}" />
    <SolidColorBrush x:Key="CyanBrush" Color="{ThemeResource AppCyanColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{ThemeResource AppSuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{ThemeResource AppWarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{ThemeResource AppDangerColor}" />
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{ThemeResource AppWarningBackgroundColor}" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="{ThemeResource AppDangerBackgroundColor}" />
    <SolidColorBrush x:Key="MetadataBrush" Color="{ThemeResource AppMetadataColor}" />
    <SolidColorBrush x:Key="FocusRingBrush" Color="{ThemeResource AppCyanColor}" />
    <SolidColorBrush x:Key="DropPanelBrush" Color="{ThemeResource AppSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="DropPanelBorderBrush" Color="{ThemeResource AppBrightBlueColor}" />
    <SolidColorBrush x:Key="DropPanelActiveBrush" Color="{ThemeResource AppDropActiveColor}" />
    <SolidColorBrush x:Key="StatusSurfaceBrush" Color="{ThemeResource AppStatusSurfaceColor}" />
    <SolidColorBrush x:Key="ButtonGhostBrush" Color="{ThemeResource AppButtonGhostColor}" />
    <SolidColorBrush x:Key="PrimaryActionBrush" Color="{ThemeResource AppPrimaryActionColor}" />
    <SolidColorBrush x:Key="PrimaryActionForegroundBrush" Color="{ThemeResource AppPrimaryActionForegroundColor}" />

    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="140" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KickerTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="140" />
        <Setter Property="Foreground" Value="{ThemeResource BrightBlueBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FormLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DashboardSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
        <Setter Property="FontSize" Value="19" />
    </Style>

    <Style x:Key="BadgeBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="{StaticResource PillCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="IconTileBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource WorkspaceSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource PanelCornerRadius}" />
    </Style>

    <Style x:Key="HeroPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="SectionPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource WorkspaceSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource PanelCornerRadius}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="MetricPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource PanelCornerRadius}" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="TabHostBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="8,8,8,4" />
    </Style>

    <Style x:Key="SurfacePillBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="CornerRadius" Value="{StaticResource PillCornerRadius}" />
        <Setter Property="Background" Value="{ThemeResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="RaisedPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="DashboardPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource WorkspaceSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource PanelCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource PanelPadding}" />
    </Style>

    <Style x:Key="DashboardElevatedPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource DashboardPanelBorderStyle}">
        <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
    </Style>

    <Style x:Key="DashboardStatusPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource DashboardPanelBorderStyle}">
        <Setter Property="Background" Value="{ThemeResource StatusSurfaceBrush}" />
        <Setter Property="Padding" Value="{StaticResource StatusPanelPadding}" />
        <Setter Property="MinHeight" Value="150" />
    </Style>

    <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="46" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style x:Key="SidebarNavButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderStrongBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="DashboardActionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="286" />
        <Setter Property="Height" Value="210" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource PanelCornerRadius}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style x:Key="DashboardActionPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource DashboardPanelBorderStyle}">
        <Setter Property="Width" Value="286" />
        <Setter Property="Height" Value="210" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="DashboardGhostButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Background" Value="{ThemeResource ButtonGhostBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style x:Key="DashboardTableHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="DashboardTableCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource DashboardPanelBorderStyle}">
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="SettingsSectionHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DashboardSectionTitleStyle}">
        <Setter Property="FontSize" Value="17" />
    </Style>

    <Style x:Key="SettingsLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsMutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="SettingsFieldComboBoxStyle" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{ThemeResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsFieldTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{ThemeResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DashboardGhostButtonStyle}">
        <Setter Property="Height" Value="42" />
    </Style>

    <Style x:Key="AccentColorButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style x:Key="InlineAlertBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="14" />
        <Setter Property="Background" Value="{ThemeResource InputSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="InlineWarningBorderStyle" TargetType="Border" BasedOn="{StaticResource InlineAlertBorderStyle}">
        <Setter Property="Background" Value="{ThemeResource WarningBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource WarningBrush}" />
    </Style>

    <Style x:Key="InlineDangerBorderStyle" TargetType="Border" BasedOn="{StaticResource InlineAlertBorderStyle}">
        <Setter Property="Background" Value="{ThemeResource DangerBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DangerBrush}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style TargetType="ToggleSwitch">
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="{StaticResource FocusRingMargin}" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource FocusRingBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="FocusVisualMargin" Value="0" />
    </Style>
</ResourceDictionary>
